# Variables de entorno - Backend Node.js
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas tu archivo .env real al repositorio.

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de datos MySQL ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=chat_base
DB_PORT=3306

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Cambia estos valores por strings aleatorios largos en producción
JWT_ACCESS_SECRET=cambia_este_secret_de_acceso_por_uno_seguro
JWT_REFRESH_SECRET=cambia_este_secret_de_refresco_por_uno_seguro
